BACKEND_URL=http://localhost:8000
MONGO_URI=mongodb://localhost:27017
MONGO_DB=mini_splunk
MONGO_COLLECTION=logs
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=24
AGENT_USERNAME=agent
AGENT_PASSWORD=agentpass123
WATCH_PATH=./logs
APP_TYPE=python            # python | node | windows

CONFIG_FILE=agent_sources.json
BATCH_SIZE=50              # flush when buffer hits this many lines
FLUSH_INTERVAL=5.0         # flush every N seconds regardless of batch size
MAX_RETRIES=3              # retry attempts before dead-lettering a batch
DEAD_LETTER_FILE=agent_dead_letter.jsonl
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
